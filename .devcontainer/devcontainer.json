{
  "image": "ghcr.io/dbushell/docker-debian/base",
  "features": {
    "ghcr.io/dbushell/docker-debian/deno:latest": {}
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "runArgs": [
    "--name",
    "dbushell",
    "--network",
    "traefik",
    "--label-file",
    ".devcontainer/labels"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "esbenp.prettier-vscode",
        "denoland.vscode-deno",
        "svelte.svelte-vscode"
      ]
    }
  }
}
